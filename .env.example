# ── Chat (LLM) ──
# Providers: openai, deepseek, anthropic, gemini
LLM_API_KEY=
LLM_PROVIDER=openai

# ── Image generation ──
# Providers: flux, openai, gemini, huggingface
IMAGE_API_KEY=
IMAGE_PROVIDER=flux

# ── Generation mode ──
# llm: LLM generates SVG directly (faster, cheaper)
# pipeline: LLM adapts prompt → image provider → preprocess → vectorize → optimize
GENERATION_MODE=llm
